# Comma-separated wallet allowlist for chairman auth gate
CHAIRMAN_WALLETS=0xYourWalletAddress

# Supabase (server-side)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Hard gate: disable any mock/fallback usage in production
REAL_DATA_ONLY=true

# HMAC secret for /api/events/agent-status webhook signature verification
WEBHOOK_SECRET=replace_with_strong_random_secret
